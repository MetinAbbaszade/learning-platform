{
	"versionGroups": [
		{
			"label": "use workspace protocol for internal packages",
			"dependencies": ["@repo/**"],
			"dependencyTypes": ["dependencies", "devDependencies"],
			"pinVersion": "workspace:*"
		},
		{
			"label": "ensure single version for shared deps",
			"dependencyTypes": ["dependencies", "devDependencies"],
			"pinVersion": "same"
		}
	],
	"semverGroups": [
		{
			"label": "enforce semver ranges",
			"range": "^",
			"dependencies": ["*"]
		}
	],
	"dependencyTypes": ["dependencies", "devDependencies"]
}
