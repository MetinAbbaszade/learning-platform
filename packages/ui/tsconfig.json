{
	"extends": "@repo/typescript-config/react-library.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "./src",
		"strictNullChecks": true,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"jsx": "react-jsx",
		"moduleResolution": "bundler",
		"module": "ESNext",
		"target": "ES2017"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
